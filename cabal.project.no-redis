-- cabal.project.no-redis
-- Excludes tmp-proc-redis because it requires hedis >= 0.16,
-- which needs GHC 9.6+ (base >= 4.18).
packages:
  tmp-proc/
  tmp-proc-postgres/
  tmp-proc-rabbitmq/
  tmp-proc-zipkin/
  hspec-tmp-proc/

test-show-details: streaming

package tmp-proc
  flags: +use-doc-tests

package postgresql-libpq
  flags: +use-pkg-config

package HsOpenSSL
  ghc-options: -optc=-Wno-discarded-qualifiers -optc=-Wno-deprecated-declarations -optc=-Wno-incompatible-pointer-types
